{
  "name": "lessonpilot-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node ./server.mjs",
    "dev:spa": "node ./scripts/vite-wrapper.mjs",
    "build": "vue-tsc --noEmit -p tsconfig.app.json && node ./scripts/vite-wrapper.mjs build && node ./scripts/vite-wrapper.mjs build --ssr src/entry-server.ts --outDir dist/server",
    "lint": "eslint .",
    "type-check": "vue-tsc --noEmit -p tsconfig.app.json",
    "preview:ssr": "node ./server.mjs"
  },
  "dependencies": {
    "@lessonpilot/shared-types": "workspace:*",
    "@sentry/node": "^10.14.0",
    "@sentry/vue": "^10.14.0",
    "@tanstack/vue-query": "^5.59.0",
    "@tiptap/extension-underline": "^2.8.0",
    "@tiptap/starter-kit": "^2.8.0",
    "@tiptap/vue-3": "^2.8.0",
    "@vue/server-renderer": "^3.5.13",
    "compression": "^1.8.1",
    "express": "^5.1.0",
    "pinia": "^3.0.2",
    "vue": "^3.5.13",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^24.0.0",
    "@vue/compiler-sfc": "^3.5.13",
    "@vitejs/plugin-vue": "^5.2.1",
    "eslint": "^9.22.0",
    "eslint-plugin-vue": "^10.0.0",
    "globals": "^16.0.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.26.0",
    "vite": "^6.3.5",
    "vue-eslint-parser": "^10.1.1",
    "vue-tsc": "^2.2.8"
  }
}
