# LessonPilot 环境变量模板
# 复制此文件为 .env 并填入真实值

APP_ENV=development
DATABASE_URL=postgresql+psycopg://lessonpilot:lessonpilot@localhost:5432/lessonpilot
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
JWT_SECRET=replace-with-a-long-random-secret  # 生产环境必须替换为至少 32 位随机强密钥
JWT_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:5173
APP_BASE_URL=http://localhost:5173

# 管理员（逗号分隔的邮箱白名单）
ADMIN_ALLOWLIST_EMAILS=

# 邮件
MAIL_DELIVERY_MODE=console
MAIL_FROM_EMAIL=hello@lessonpilot.com
MAIL_FROM_NAME=LessonPilot
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
FEEDBACK_NOTIFY_EMAIL=hello@lessonpilot.com

# 邮箱验证 / 密码重置
VERIFY_EMAIL_TOKEN_EXPIRE_HOURS=48
RESET_PASSWORD_TOKEN_EXPIRE_MINUTES=30

# LLM Provider
LLM_PROVIDER=fake
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_THINKING=disabled
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-Text-01
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_EMBEDDING_MODEL=embo-01

# Embedding
EMBEDDING_PROVIDER=local_bge
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu

# RAG
RAG_ENABLED=true
RAG_TRIGGER_MODE=topic_route
RAG_MAX_KNOWLEDGE_TOKENS=3000
RAG_TOP_K=8

# 公益运营 - 配额与成本
QUOTA_ENABLED=true
DAILY_GENERATION_LIMIT=20
MONTHLY_GENERATION_LIMIT=300
COST_TRACKING_ENABLED=true

# 公益运营 - 内容安全
CONTENT_FILTER_ENABLED=true
CONTENT_FILTER_MODE=warn
